{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@stackpay/config": [
        "../../packages/config/src"
      ],
      "@stackpay/domain": [
        "../../packages/domain/src"
      ],
      "@stackpay/integrations": [
        "../../packages/integrations/src"
      ],
      "@stackpay/sdk": [
        "../../packages/sdk/src"
      ],
      "@stackpay/ui": [
        "../../packages/ui/src"
      ]
    },
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
